 "query": "SELECT\r\n    g.item AS grocery,\r\n    b.location,\r\n    b.actual_qty,\r\n    g.base_uom AS uom\r\nFROM `tabGrocery Bin` b\r\nJOIN `tabGrocery` g ON g.name = b.grocery\r\nWHERE b.actual_qty != 0\r\nORDER BY g.item, b.location;",
